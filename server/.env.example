MONGODB_URI=mongodb://127.0.0.1:27017/areti
JWT_SECRET=change-this-to-a-random-secret-string
PORT=4000

# Production:  https://demetriosbride-bg.com
# Development: http://localhost:5173
CORS_ORIGIN=http://localhost:5173
SITE_URL=https://demetriosbride-bg.com

# Admin seed (използва се само при първи seed на базата)
ADMIN_EMAIL=admin@areti.bg

# Brevo (Sendinblue) — за изпращане на emails
BREVO_API_KEY=
ARETI_EMAIL=info@areti.bg

# Admin notification emails (comma-separated).
# All these addresses receive: booking notifications, system error alerts.
# If empty, falls back to ARETI_EMAIL.
ADMIN_EMAILS=info@your-domain.com,second-admin@your-domain.com
