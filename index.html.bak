,view_all:"Виж цялата колекция",story_eye:"За Арети",story_title:"Изкуство",story_title_em:"и Време",story_p1:"От 2014 г. ателие Арети превръща мечтаната рокля във факт. Всеки силует е резултат от 200+ часа ръчна работа — френска коприна, фламандска дантела, мъниста, шити по една.",story_p2:"Нашата колекция Романса MMXXVI празнува тихата сила на съвременната булка — без излишно, без шум.",story_cta:"Историята",services_eye:"Опитът",services_title:"Един ден,",services_title_em:"за теб",service_1_title:"Лична консултация",service_1_desc:"90-минутна среща с консултант, чай, шампанско, и достъп до цялата колекция.",service_2_title:"Премерване и шев",service_2_desc:"До 5 пробни срещи в собствено студио. Размер, дължина, дантела — всичко по мярка.",service_3_title:"Услуги в деня",service_3_desc:"Стилизация, обличане в студиото, и пакет за пътуване с конусна торба.",cta_band:"Запиши се за безплатна консултация",cta_band_btn:"Резервирай час"},collection:{crumb:"Начало / Колекция",title:"Колекция",title_em:"Романса",count:"12 силуета · MMXXVI",filter:"Филтри",sort:"Подреди",sort_new:"Най-нови",reset:"Изчисти",results:e=>`${e} модела`,groups:{silhouette:"Силует",fabric:"Материя",neckline:"Деколте",price:"Цена"},silhouettes:["A-силует","Прав","Принцеса","Сирена","Балон","Ампир"],fabrics:["Коприна","Дантела","Тюл","Шифон","Сатен","Мъниста"],necklines:["V-образно","Без рамене","Sweetheart","Илюзия","Quadrato","Стойка"]},product:{crumb_back:"Колекция Романса",designer:"Атолие Арети · MMXXVI",ref:"Референция",price_from:"от",price_note:"Цената включва 4 пробни срещи и шев по мярка",desc:"Силует с дълъг шлейф, ръчно бродирана дантела и двоен тюл. Деколте Sweetheart с илюзия от прозрачна дантела по гърба. Шито от френска коприна и фламандска дантела.",size:"Размер",size_guide:"Таблица размери",size_warn:"Не намираш своя размер? Шием по мярка.",cta_book:"Запази проба",cta_inquire:"Попитай за роклята",specs:{fabric:"Материя",fabric_v:"Коприна, фламандска дантела",silhouette:"Силует",silhouette_v:"Сирена",neckline:"Деколте",neckline_v:"Sweetheart с илюзия",train:"Шлейф",train_v:"Catedral · 1.8м",details:"Детайли",details_v:"Ръчна бродерия с мъниста, обвити копчета"},similar:"Подобни силуети"},booking:{title:"Запази",title_em:"проба",lede:"Резервирай 90 минутна частна среща в нашето студио. Безплатна, без ангажимент.",steps:["Тип","Локация","Дата","Детайли"],step1_eye:"Стъпка 01 от 04",step1_title:"Тип",step1_title_em:"среща",step1_help:"Избери преживяването, което желаеш. Можеш да го промениш по-късно.",step2_eye:"Стъпка 02 от 04",step2_title:"Студио",step2_help:"Двете ни студия предлагат пълно преживяване. Избери това, което ти е удобно.",step3_eye:"Стъпка 03 от 04",step3_title:"Дата и",step3_title_em:"час",step3_help:"Изборът ти е за 90 минути. Препоръчваме среща поне 6 месеца преди сватбата.",step4_eye:"Стъпка 04 от 04",step4_title:"Твоите",step4_title_em:"детайли",step4_help:"Малко информация, за да се подготвим за теб.",types:[{tag:"Ново",title:"Първа консултация",desc:"90 мин. с консултант, чай, шампанско, достъп до цялата колекция.",price:"Безплатна"},{tag:"Премиум",title:"Couture сесия",desc:"2 часа лично с дизайнерката. Колекция + персонализация.",price:"120 лв."},{tag:"Експрес",title:"Бърза проба",desc:"45 мин. за конкретен модел, който вече сте набелязали.",price:"Безплатна"},{tag:"За семейство",title:"Семейна проба",desc:"Удобна стая, място за свита от 4 души. Шампанско включено.",price:"Безплатна"}],locations:[{name:"София",addr:"ул. Шипка 18, ет.2 · до НДК",hours:"Вт – Сб · 11:00 – 19:00"},{name:"Пловдив",addr:"ул. Княз Александър I 24 · Капана",hours:"Ср – Сб · 11:00 – 18:00"}],labels:{name:"Име",phone:"Телефон",email:"Имейл",wedding:"Сватбена дата (ако е известна)",budget:"Ориентировъчен бюджет",notes:"Забележки или въпроси"},summary_eye:"Твоята резервация",summary_title:"Резюме",summary_empty:"Не е избрано",summary_rows:["Тип","Студио","Дата","Час","Име"],back:"Назад",next:"Напред",confirm:"Потвърди резервация",confirmation_title:"Готово.",confirmation_title_em:"До скоро.",confirmation_p:"Ще получиш потвърждение на имейла си в рамките на 24 часа. Очакваме те с шампанско.",conf_card_title:"Резервацията ти",back_home:"Към началото"},about:{crumb:"За нас",title:"Историята",title_em:"Арети",lede:"Дванадесет години изкуство, копринени конци, и трепет в сърцето на София.",stats:[{num:"2014",label:"Година на основаване"},{num:"1200+",label:"Изработени рокли"},{num:"180h",label:"Среден труд за рокля"},{num:"12",label:"Държави, в които пътуваме"}],timeline:[{yr:"2014",title:"Първото ателие в София.",p:"Арети основава студиото си с три рокли и пет порции вяра. Първата булка минава през вратите след две седмици."},{yr:"2017",title:'Колекция "Софѝя Прима"',p:"Първата собствена колекция от 12 силуета — представена на 200 гости в галерия в Пловдив."},{yr:"2020",title:"Couture линия",p:"Откриване на couture лабораторията. Всяка рокля — едно от вид, шита изцяло на ръка."},{yr:"2023",title:"Второ студио — Пловдив",p:"Капана получава своя ателие. Бутиково пространство в реконструирана къща от 1890 г."},{yr:"2026",title:'Колекция "Романса"',p:"Дванадесет силуета, вдъхновени от тихата сила на съвременната булка."}]},contact:{title:"Контакти",title_em:"и студия",lede:"Намери ни в София или Пловдив. Записването е по уговорка.",directions:"Упътвания",book:"Запази час",cities:[{name:"София",em:"флагман",addr:`ул. Шипка 18, ет.2
