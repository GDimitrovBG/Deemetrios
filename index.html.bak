<!doctype html>
<html lang="bg">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Арети — Bridal Couture · Sofia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>:root{--bg: #f6f1e8;--bg-soft: #faf6ee;--bg-deep: #ede5d3;--paper: #fffdf8;--ink: #1a1612;--ink-soft: #4a3f33;--ink-mute: #8a7d6c;--rule: #d9cfb8;--rule-soft: #e8dfc9;--champagne: #c4a373;--champagne-deep: #a08555;--nude: #d9c5a8;--blush: #e8d5c4;--gold: #b8965a;--f-display: "Italiana", "Cormorant Garamond", serif;--f-serif: "Cormorant Garamond", "Times New Roman", serif;--f-sans: "Jost", "Helvetica Neue", system-ui, sans-serif;--f-mono: "JetBrains Mono", ui-monospace, monospace;--s-1: 4px;--s-2: 8px;--s-3: 12px;--s-4: 16px;--s-5: 24px;--s-6: 32px;--s-7: 48px;--s-8: 64px;--s-9: 96px;--s-10: 128px;--maxw: 1440px;--gutter: clamp(20px, 4vw, 64px)}.theme-noir{--bg: #14110d;--bg-soft: #1c1814;--bg-deep: #0c0a08;--paper: #1a1612;--ink: #f5ecd8;--ink-soft: #d8cbb0;--ink-mute: #8a7d65;--rule: #3a3329;--rule-soft: #28231b}*{box-sizing:border-box;margin:0;padding:0}html,body{background:var(--bg);color:var(--ink)}body{font-family:var(--f-sans);font-size:15px;line-height:1.5;-webkit-font-smoothing:antialiased;font-feature-settings:"ss01","kern";letter-spacing:.005em;overflow-x:hidden}img{max-width:100%;display:block}button{font:inherit;cursor:pointer;border:0;background:0;color:inherit}a{color:inherit;text-decoration:none}.t-display{font-family:var(--f-display);font-weight:400;letter-spacing:-.005em;line-height:.92}.t-serif{font-family:var(--f-serif);font-weight:400;line-height:1.15;letter-spacing:-.01em}.t-italic{font-family:var(--f-serif);font-style:italic}.t-eyebrow{font-family:var(--f-sans);font-size:11px;letter-spacing:.32em;text-transform:uppercase;font-weight:500;color:var(--ink-soft)}.t-meta{font-family:var(--f-sans);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-mute)}.t-mono{font-family:var(--f-mono);font-size:11px;letter-spacing:.1em}.container{max-width:var(--maxw);margin:0 auto;padding:0 var(--gutter)}.full{width:100%}.row{display:flex}.col{display:flex;flex-direction:column}.btn{display:inline-flex;align-items:center;gap:10px;padding:14px 26px;font-family:var(--f-sans);font-size:11px;letter-spacing:.28em;text-transform:uppercase;font-weight:500;border:1px solid var(--ink);background:transparent;color:var(--ink);transition:all .24s cubic-bezier(.2,.7,.2,1);cursor:pointer;white-space:nowrap}.btn:hover,.btn-solid{background:var(--ink);color:var(--bg)}.btn-solid:hover{background:var(--champagne-deep);border-color:var(--champagne-deep);color:var(--bg)}.btn-light{border-color:var(--bg);color:var(--bg)}.btn-light:hover{background:var(--bg);color:var(--ink)}.btn-link{border:0;border-bottom:1px solid currentColor;padding:4px 0;text-transform:uppercase;letter-spacing:.24em;font-size:11px;font-weight:500}.ph{position:relative;background:linear-gradient(135deg,#e8dfc9,#d9c5a8,#c4a373);overflow:hidden;display:block}.ph:before{content:"";position:absolute;top:0;right:0;bottom:0;left:0;background-image:repeating-linear-gradient(135deg,rgba(255,253,248,.06) 0,rgba(255,253,248,.06) 1px,transparent 1px,transparent 8px)}.ph:after{content:attr(data-label);position:absolute;top:0;right:0;bottom:0;left:0;display:grid;place-items:center;font-family:var(--f-mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:#1a161273;text-align:center;padding:16px}.ph-img{background-size:cover;background-position:center}.ph-img:before,.ph-img:after{display:none}.rule{height:1px;background:var(--rule);width:100%}.rule-vert{width:1px;background:var(--rule);align-self:stretch}@keyframes fadeUp{0%{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}@keyframes fadeIn{0%{opacity:0}to{opacity:1}}.fade-up{animation:fadeUp .72s cubic-bezier(.2,.7,.2,1) both}.fade-in{animation:fadeIn .6s ease both}.delay-1{animation-delay:80ms}.delay-2{animation-delay:.16s}.delay-3{animation-delay:.24s}.delay-4{animation-delay:.32s}.delay-5{animation-delay:.4s}.page-enter{animation:fadeUp .6s cubic-bezier(.2,.7,.2,1) both}.nav-bar{position:fixed;top:0;left:0;right:0;z-index:100;background:#f6f1e8d9;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--rule-soft);transition:all .28s ease}.nav-bar.transparent{background:transparent;border-bottom-color:transparent;color:var(--bg)}.nav-bar.transparent .nav-link,.nav-bar.transparent .brand-mark{color:var(--bg)}.nav-bar.scrolled{background:#f6f1e8f5;border-bottom-color:var(--rule-soft);color:var(--ink)}.nav-bar.scrolled .nav-link,.nav-bar.scrolled .brand-mark{color:var(--ink)}.nav-inner{max-width:var(--maxw);margin:0 auto;padding:0 var(--gutter);display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:76px;gap:24px}.nav-left,.nav-right{display:flex;align-items:center;gap:32px}.nav-right{justify-content:flex-end}.nav-link{font-size:11px;letter-spacing:.24em;text-transform:uppercase;font-weight:500;position:relative;padding:4px 0;cursor:pointer}.nav-link:after{content:"";position:absolute;left:0;right:0;bottom:-2px;height:1px;background:currentColor;transform:scaleX(0);transform-origin:left;transition:transform .24s ease}.nav-link:hover:after,.nav-link.active:after{transform:scaleX(1)}.brand-mark{font-family:var(--f-display);font-size:28px;letter-spacing:.14em;cursor:pointer;text-align:center}.brand-mark .sub{display:block;font-family:var(--f-sans);font-size:8px;letter-spacing:.4em;margin-top:-2px;opacity:.7}.lang-toggle{display:inline-flex;border:1px solid currentColor;border-radius:999px;padding:2px;font-size:10px;letter-spacing:.16em}.lang-toggle button{padding:4px 10px;border-radius:999px;color:currentColor;opacity:.6;font-weight:500}.lang-toggle button.active{background:currentColor;opacity:1}.lang-toggle button.active span{color:var(--bg);mix-blend-mode:difference}.icon-btn{width:32px;height:32px;display:grid;place-items:center;border-radius:50%;transition:background .2s ease}.icon-btn:hover{background:#c4a3732e}.hero{position:relative;width:100%;height:100vh;min-height:720px;overflow:hidden}.hero-bg{position:absolute;top:0;right:0;bottom:0;left:0;background:linear-gradient(160deg,#d9c5a8,#c4a373 40%,#8a7556)}.hero-bg:after{content:"";position:absolute;top:0;right:0;bottom:0;left:0;background:linear-gradient(180deg,#0000002e,#0000000d 30%,#00000073)}.hero-content{position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:120px var(--gutter) 60px;color:var(--bg-soft)}.hero-v1 .hero-content{justify-content:space-between;align-items:center;text-align:center}.hero-v1 .top-strip{display:flex;justify-content:space-between;width:100%;font-size:10px;letter-spacing:.32em;text-transform:uppercase;opacity:.85}.hero-v1 h1{font-family:var(--f-display);font-size:clamp(80px,14vw,220px);line-height:.86;letter-spacing:-.01em}.hero-v1 h1 em{font-family:var(--f-serif);font-style:italic;font-size:.78em;display:block}.hero-v1 .bottom-strip{display:flex;justify-content:space-between;align-items:end;width:100%}.hero-v1 .tag{max-width:280px;text-align:left;font-family:var(--f-serif);font-size:18px;font-style:italic;line-height:1.4}.hero-v2{height:100vh;min-height:720px;display:grid;grid-template-columns:1.1fr 1fr}.hero-v2 .hero-img{background:linear-gradient(160deg,#c4a373,#8a7556);position:relative}.hero-v2 .hero-text{background:var(--bg);padding:100px clamp(40px,5vw,90px) 60px;display:flex;flex-direction:column;justify-content:space-between;color:var(--ink)}.hero-v2 .issue{display:flex;gap:20px;align-items:center;font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-mute)}.hero-v2 .issue .dot{width:4px;height:4px;border-radius:50%;background:var(--champagne)}.hero-v2 h1{font-family:var(--f-display);font-size:clamp(72px,9vw,168px);line-height:.9}.hero-v2 h1 em{font-family:var(--f-serif);font-style:italic;display:block}.hero-v2 .lede{font-family:var(--f-serif);font-size:22px;line-height:1.3;font-style:italic;max-width:420px;color:var(--ink-soft);margin-top:24px}.hero-v2 .meta-row{display:flex;justify-content:space-between;align-items:end;gap:20px}.hero-v2 .meta-stack{display:flex;flex-direction:column;gap:6px}.hero-v3{background:#0c0a08;color:var(--bg)}.hero-v3 .hero-bg{background:linear-gradient(140deg,#2a1f15,#1a1612,#0c0a08)}.hero-v3 .hero-bg:after{background:linear-gradient(180deg,#00000073,#0003,#000000d9)}.hero-v3 .hero-content{justify-content:end;align-items:start;padding-bottom:80px}.hero-v3 .marquee{font-family:var(--f-display);font-size:clamp(140px,22vw,380px);line-height:.85;letter-spacing:-.02em;white-space:nowrap;margin-left:-8px}.hero-v3 .marquee em{font-family:var(--f-serif);font-style:italic;color:var(--champagne)}.hero-v3 .v3-row{display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:40px;width:100%;align-items:end;margin-top:20px}.hero-v3 .v3-row p{font-family:var(--f-serif);font-size:17px;line-height:1.4;font-style:italic;max-width:380px}.hero-v3 .v3-num{font-family:var(--f-display);font-size:64px;line-height:1;color:var(--champagne)}.hero-v3 .v3-num+span{font-size:10px;letter-spacing:.3em;text-transform:uppercase;opacity:.6;display:block;margin-top:8px}.hero-scroll{position:absolute;bottom:30px;left:50%;transform:translate(-50%);font-size:10px;letter-spacing:.3em;text-transform:uppercase;display:flex;flex-direction:column;align-items:center;gap:10px;z-index:3;opacity:.85}.hero-scroll .line{width:1px;height:36px;background:currentColor;animation:scrollPulse 2.4s ease-in-out infinite}@keyframes scrollPulse{0%,to{transform:scaleY(.4);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}}.section{padding:var(--s-10) var(--gutter);max-width:var(--maxw);margin:0 auto}.section-tight{padding:var(--s-9) var(--gutter)}.sec-head{display:grid;grid-template-columns:auto 1fr auto;gap:32px;align-items:end;margin-bottom:var(--s-8)}.sec-head h2{font-family:var(--f-display);font-size:clamp(48px,6vw,96px);line-height:.95;grid-column:2;text-align:center;letter-spacing:-.01em}.sec-head h2 em{font-family:var(--f-serif);font-style:italic}.sec-head .left,.sec-head .right{font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--ink-mute);padding-bottom:12px}.sec-head .right{text-align:right}.dress-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}.dress-card{position:relative;cursor:pointer;overflow:hidden}.dress-card .dress-img{aspect-ratio:3/4;background:linear-gradient(135deg,#e8dfc9,#c4a373);transition:transform .7s cubic-bezier(.2,.7,.2,1)}.dress-card:hover .dress-img{transform:scale(1.04)}.dress-card .dress-info{padding:18px 4px 4px;display:flex;justify-content:space-between;align-items:start;gap:12px}.dress-card .dress-info h3{font-family:var(--f-serif);font-size:22px;font-weight:400;letter-spacing:-.005em}.dress-card .dress-info .meta{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-mute);margin-top:4px}.dress-card .price{font-family:var(--f-serif);font-size:18px;font-style:italic;color:var(--ink-soft)}.dress-card .quick{position:absolute;bottom:calc(100% - 50px);left:50%;transform:translate(-50%,100%);background:var(--paper);padding:12px 22px;font-size:10px;letter-spacing:.28em;text-transform:uppercase;font-weight:500;opacity:0;transition:all .32s cubic-bezier(.2,.7,.2,1);pointer-events:none;border:1px solid var(--ink);white-space:nowrap}.dress-card:hover .quick{opacity:1;transform:translate(-50%);pointer-events:auto}.dress-card .badge{position:absolute;top:16px;left:16px;background:var(--paper);padding:4px 10px;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink)}.editorial{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}.editorial.flip{direction:rtl}.editorial.flip>*{direction:ltr}.editorial-img{aspect-ratio:4/5;background:linear-gradient(160deg,#d9c5a8,#8a7556)}.editorial-content h3{font-family:var(--f-display);font-size:clamp(42px,5vw,80px);line-height:.95;margin-bottom:28px}.editorial-content h3 em{font-family:var(--f-serif);font-style:italic}.editorial-content p{font-family:var(--f-serif);font-size:19px;line-height:1.55;color:var(--ink-soft);margin-bottom:18px;max-width:520px}.marquee-strip{padding:60px 0;border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);overflow:hidden;white-space:nowrap;background:var(--bg-soft)}.marquee-track{display:inline-flex;gap:80px;animation:marqueeMove 36s linear infinite;font-family:var(--f-display);font-size:clamp(48px,7vw,112px);line-height:1;align-items:center}.marquee-track span{display:inline-block}.marquee-track span em{font-family:var(--f-serif);font-style:italic;color:var(--champagne-deep)}.marquee-track .sep{width:14px;height:14px;border-radius:50%;background:var(--champagne);display:inline-block}@keyframes marqueeMove{to{transform:translate(-50%)}}.footer{background:var(--ink);color:var(--bg);padding:var(--s-9) var(--gutter) var(--s-6)}.footer .inner{max-width:var(--maxw);margin:0 auto}.footer .top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:var(--s-8);border-bottom:1px solid rgba(255,253,248,.12)}.footer h4{font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--champagne);margin-bottom:22px;font-weight:500}.footer .brand-big{font-family:var(--f-display);font-size:88px;line-height:.9;letter-spacing:.02em}.footer .brand-big em{font-family:var(--f-serif);font-style:italic;color:var(--champagne)}.footer .brand-tag{font-family:var(--f-serif);font-style:italic;font-size:17px;margin-top:12px;max-width:320px;opacity:.8}.footer ul{list-style:none;display:flex;flex-direction:column;gap:10px}.footer ul a{font-size:13px;font-family:var(--f-serif);opacity:.85;transition:opacity .2s}.footer ul a:hover{opacity:1;color:var(--champagne)}.footer .bottom{padding-top:28px;display:flex;justify-content:space-between;align-items:center;font-size:10px;letter-spacing:.24em;text-transform:uppercase;opacity:.6}.collection-head{padding:140px var(--gutter) 40px;max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:1fr auto;align-items:end;gap:32px;border-bottom:1px solid var(--rule)}.collection-head h1{font-family:var(--f-display);font-size:clamp(72px,11vw,180px);line-height:.9}.collection-head h1 em{font-family:var(--f-serif);font-style:italic}.collection-head .meta-stack{text-align:right}.collection-head .crumb{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:12px}.collection-head .count{font-family:var(--f-serif);font-size:16px;font-style:italic;color:var(--ink-soft)}.filter-bar{position:sticky;top:76px;z-index:50;background:var(--bg);border-bottom:1px solid var(--rule);padding:16px var(--gutter)}.filter-bar .inner{max-width:var(--maxw);margin:0 auto;display:flex;align-items:center;gap:24px}.filter-chip{font-size:10px;letter-spacing:.24em;text-transform:uppercase;padding:8px 16px;border:1px solid var(--rule);background:var(--bg);display:inline-flex;align-items:center;gap:8px;cursor:pointer;transition:all .2s;font-weight:500}.filter-chip:hover{border-color:var(--ink)}.filter-chip.active{background:var(--ink);color:var(--bg);border-color:var(--ink)}.filter-chip .chev{width:8px;height:8px;border-right:1px solid currentColor;border-bottom:1px solid currentColor;transform:rotate(45deg) translate(-2px,-2px)}.filter-bar .results{margin-left:auto;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-mute)}.filter-bar .sort{font-size:10px;letter-spacing:.24em;text-transform:uppercase;font-weight:500;display:inline-flex;gap:8px;align-items:center;cursor:pointer}.filter-panel{background:var(--bg-soft);border-bottom:1px solid var(--rule);padding:32px var(--gutter);overflow:hidden}.filter-panel .inner{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:48px}.filter-panel h5{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-mute);margin-bottom:14px}.filter-options{display:flex;flex-wrap:wrap;gap:8px}.filter-pill{font-size:12px;font-family:var(--f-serif);padding:6px 14px;border:1px solid var(--rule);border-radius:999px;background:var(--paper);cursor:pointer;transition:all .18s}.filter-pill:hover{border-color:var(--ink)}.filter-pill.on{background:var(--ink);color:var(--bg);border-color:var(--ink)}.filter-pill .x{margin-left:6px;opacity:.6}.range-track{height:1px;background:var(--rule);position:relative;margin:24px 6px 8px}.range-fill{position:absolute;height:1px;background:var(--ink)}.range-knob{position:absolute;top:50%;width:12px;height:12px;border-radius:50%;background:var(--ink);transform:translate(-50%,-50%);cursor:grab}.range-vals{display:flex;justify-content:space-between;font-family:var(--f-mono);font-size:11px;color:var(--ink-soft)}.collection-grid{padding:24px var(--gutter) 80px;max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:6px 4px}.product{padding:100px 0 0;max-width:var(--maxw);margin:0 auto}.product-crumb{padding:24px var(--gutter);font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-mute)}.product-crumb a{padding-right:12px;margin-right:12px;border-right:1px solid var(--rule)}.product-main{display:grid;grid-template-columns:1.4fr 1fr;gap:64px;padding:0 var(--gutter) var(--s-9)}.product-gallery{display:grid;grid-template-columns:1fr 1fr;gap:4px}.product-gallery .main-img{aspect-ratio:3/4;grid-column:span 2;cursor:zoom-in;background:linear-gradient(160deg,#d9c5a8,#8a7556)}.product-gallery .thumb{aspect-ratio:3/4;background:linear-gradient(135deg,#e8dfc9,#c4a373);cursor:pointer}.product-info{position:sticky;top:100px;align-self:start;padding-top:40px}.product-info .designer{font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--ink-mute)}.product-info h1{font-family:var(--f-display);font-size:64px;line-height:.95;margin:14px 0 8px}.product-info h1 em{font-family:var(--f-serif);font-style:italic}.product-info .ref{font-family:var(--f-mono);font-size:11px;color:var(--ink-mute)}.product-info .price{font-family:var(--f-serif);font-size:28px;font-style:italic;margin:28px 0 8px}.product-info .price-note{font-size:11px;color:var(--ink-mute);letter-spacing:.16em}.product-info .desc{font-family:var(--f-serif);font-size:17px;line-height:1.5;margin:32px 0;color:var(--ink-soft)}.product-info .spec-row{display:grid;grid-template-columns:auto 1fr;gap:32px;padding:14px 0;border-top:1px solid var(--rule)}.product-info .spec-row:last-of-type{border-bottom:1px solid var(--rule)}.product-info .spec-row dt{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-mute)}.product-info .spec-row dd{font-family:var(--f-serif);font-size:16px}.size-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:6px;margin:14px 0 8px}.size-pick{aspect-ratio:1;border:1px solid var(--rule);font-family:var(--f-serif);font-size:14px;cursor:pointer;transition:all .18s}.size-pick:hover{border-color:var(--ink)}.size-pick.on{background:var(--ink);color:var(--bg);border-color:var(--ink)}.size-pick.out{color:var(--ink-mute);position:relative;cursor:not-allowed}.size-pick.out:after{content:"";position:absolute;inset:50% 8px auto;height:1px;background:var(--ink-mute)}.cta-stack{display:flex;flex-direction:column;gap:12px;margin-top:32px}.lightbox{position:fixed;top:0;right:0;bottom:0;left:0;z-index:200;background:#14110df2;-webkit-backdrop-filter:blur(20px);backdrop-filter:blur(20px);display:flex;align-items:center;justify-content:center;padding:60px}.lightbox img,.lightbox .ph{max-height:90vh;max-width:90vw;width:auto;aspect-ratio:3/4}.lightbox-close{position:absolute;top:30px;right:30px;color:var(--bg);font-size:11px;letter-spacing:.3em;text-transform:uppercase;display:flex;align-items:center;gap:10px}.lightbox-nav{position:absolute;top:50%;transform:translateY(-50%);color:var(--bg);width:60px;height:60px;display:grid;place-items:center;border:1px solid rgba(255,255,255,.2);border-radius:50%;font-family:var(--f-serif);font-size:24px;transition:all .2s}.lightbox-nav:hover{background:var(--bg);color:var(--ink)}.lightbox-nav.prev{left:40px}.lightbox-nav.next{right:40px}.lightbox-counter{position:absolute;bottom:30px;left:50%;transform:translate(-50%);color:var(--bg);font-family